{
  "name": "@workspace/desktop-wb",
  "version": "1.0.0",
  "description": "AD Unit R — Ad Optimizer + Unit Economics (Desktop)",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.mjs",
    "dist:win": "node build.mjs && electron-builder --win --x64",
    "dist:win:norebuild": "electron-builder --win --x64"
  },
  "build": {
    "appId": "ru.adunitr.desktop",
    "productName": "AD Unit R",
    "copyright": "Copyright © 2026",
    "directories": {
      "buildResources": "build-resources",
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "server-assets",
        "to": "server-assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build-resources/icon.ico",
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AD Unit R",
      "installerLanguages": ["ru_RU", "en_US"],
      "language": "1049"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
