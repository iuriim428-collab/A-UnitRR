PORT=8092
NODE_ENV=production

# Serve the built frontend from the API process.
SERVE_FRONTEND_DIR=/opt/ad-unit-r/current/artifacts/wb-optimizer/dist/public

# Application secrets.
SESSION_SECRET=replace-with-long-random-secret
APP_PASSWORD=replace-with-strong-shared-password

# Database.
DATABASE_URL=postgresql://ad_unit_r:replace_me@127.0.0.1:5432/heliumdb
DATABASE_SSL=false

# Reverse proxy / cookies.
TRUST_PROXY=true
COOKIE_SECURE=true

# Optional fallbacks.
# Usually you do not need these when api_settings is populated in PostgreSQL.
# WB_API_KEY=
# YM_OAUTH_TOKEN=
# YM_FBY_CAMPAIGN_ID=
# YM_FBS_CAMPAIGN_ID=
# OZON_CLIENT_ID=
# OZON_API_KEY=
# OZON_PERF_CLIENT_ID=
# OZON_PERF_CLIENT_SECRET=
